   "source": [
    "# Scenario Demo\n",
    "This notebook shows how to **create**, **save**, **load**, and **switch** between reproducible CARLA scenarios using `WorldManager` and `Scenario`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "e15b0ac9",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "<Popen: returncode: None args: 'CarlaUE4.exe'>"
      ]
     },
     "execution_count": 1,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "# Launch CARLA (skip if already running)\n",
    "import subprocess\n",
    "subprocess.Popen(\"CarlaUE4.exe\", shell=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f262287d",
   "metadata": {},
   "source": [
    "## 0. List available maps\n",
    "Query the running CARLA server for all available maps."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "3a2dee97",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Town01\n",
      "Town01_Opt\n",
      "Town02\n",
      "Town02_Opt\n",
      "Town03\n",
      "Town03_Opt\n",
      "Town04\n",
      "Town04_Opt\n",
      "Town05\n",
      "Town05_Opt\n",
      "Town10HD\n",
      "Town10HD_Opt\n",
      "AnnotationColorLandscape\n",
      "['Town01', 'Town01_Opt', 'Town02', 'Town02_Opt', 'Town03', 'Town03_Opt', 'Town04', 'Town04_Opt', 'Town05', 'Town05_Opt', 'Town10HD', 'Town10HD_Opt', 'AnnotationColorLandscape']\n"
     ]
    }
   ],
   "source": [
    "import carla\n",
    "\n",
    "client = carla.Client(\"127.0.0.1\", 2000)\n",
    "client.set_timeout(10.0)\n",
    "\n",
    "maps = client.get_available_maps()\n",
    "for m in maps:\n",
    "    print(m)\n",
    "\n",
    "print([m.split(\"/\")[-1] for m in maps])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "af1088d9",
   "metadata": {},
   "source": [
    "## 1. Generate scenarios\n",
    "Build the full scenario list using the generator and save them to disk."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "d62e63b8",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Generated 56 scenarios\n",
      "56\n",
      "Saved scenarios to: d:\\Projectes\\TFG\\MIREIA\\scenarios\\14D_HardRainSunset_Town04_LowVol\n"
     ]
    }
   ],
   "source": [
    "from MIREIA.simulation.scenarios import generate_mireia_dataset\n",
    "from MIREIA.simulation.world_manager import WorldManager\n",
    "\n",
    "scenarios = generate_mireia_dataset()\n",
    "print(f\"Generated {len(scenarios)} scenarios\")\n",
    "\n",
    "for scenario in scenarios:\n",
    "    scenario.save()\n",
    "\n",
    "print(len(scenarios))\n",
    "\n",
    "scenarios_to_run = scenarios[29:55]  # Run the first 5 scenarios for demonstration\n",
    "print(f\"Saved scenarios to: {scenario.folder_path}\")"
   ]
  },
