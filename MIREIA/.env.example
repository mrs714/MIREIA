# Copy this file to .env and adjust the values. Every entry is optional:
# config.py falls back to the defaults shown here when a variable is unset.

# CARLA connection
CARLA_HOST=127.0.0.1
CARLA_PORT=2000

# Paths (default to MIREIA/scenarios, MIREIA/trials, MIREIA/models when unset)
PATH_TO_SCENARIOS=
PATH_TO_TRIALS=
PATH_TO_MODELS=

# Reproducibility
MIREIA_RANDOM_SEED=42
