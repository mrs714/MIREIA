# 1. Ignore everything
*

# 2. But do not ignore the .gitignore file itself
!.gitignore

# 3. Allow specific files
!README.md
!test.ipynb
!scenario_demo.ipynb
!train_demo.ipynb
!trial_demo.ipynb
!model_demo.ipynb
!queued_inference_demo.ipynb
!feature_analysis.ipynb
!composed_inference_analysis.ipynb
!trial_builder.ipynb
!trial_batch_runner.ipynb
!trial_slow_batch_runner.ipynb
!trial_models_batch_runner.ipynb

# 4. Allow a specific folder
# Note: You must allow the folder itself AND everything inside it
!my_scripts/
!my_scripts/**
!MIREIA/
!MIREIA/**
# The .env.example file is a template for the .env file, which should not be tracked by git, but we want to allow it to be created and modified locally
MIREIA/.env 

# Ignore per-scenario datasets
MIREIA/scenarios/**/dataset/
MIREIA/scenarios/**/dataset.jsonl
MIREIA/scenarios/**/dataset_labeled.jsonl
MIREIA/scenarios/**/*.mp4

# Ignore per trial datasets
MIREIA/trials/**/images/
MIREIA/trials/**/dataset.jsonl
MIREIA/trials/**/*.mp4
MIREIA/trials/**/*.png

# Ignore model weights until i can divide them into smaller files
*.pt
*.pth

# 5. Allow certain file types anywhere
!*.png
!*.cpp

# Ignore generated scenario risk-map images (must be after !*.png)
MIREIA/scenarios/**/risk_map_*.png

# Ignore any __pycache__ wherever it is
__pycache__/
**/__pycache__/
__pycache__/**
*.pyc
MIREIA/**/__pycache__/
MIREIA/**/__pycache__/**
MIREIA/**/*.pyc
MIREIA/**/*.pyo
*.pyo